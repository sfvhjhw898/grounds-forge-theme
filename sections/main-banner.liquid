<section class="grounds-hero" style="position:relative;min-height:100svh;background:#2C1810;overflow:hidden;">
  
  <div aria-hidden="true" style="position:absolute;bottom:-0.12em;left:-0.03em;font-family:'Playfair Display',Georgia,serif;font-size:clamp(100px,16vw,260px);font-weight:400;font-style:italic;color:rgba(139,69,19,0.07);line-height:1;pointer-events:none;z-index:0;user-select:none;white-space:nowrap;">Grounds</div>

  <div class="grounds-hero-grid" style="display:grid;grid-template-columns:1fr 1fr;min-height:100svh;position:relative;z-index:1;">
    
    <div style="display:flex;flex-direction:column;padding:clamp(40px,6vw,100px) clamp(32px,5vw,72px);">
      
      <span style="display:inline-block;font-family:'Source Serif 4',Georgia,serif;font-size:10px;letter-spacing:0.32em;text-transform:uppercase;color:#8B4513;border:1px solid rgba(139,69,19,0.45);padding:6px 14px;align-self:flex-start;margin-bottom:auto;margin-top:0;">Est. MMX · Single Origin</span>

      <div style="margin-top:auto;width:100%;">
        <h1 style="font-family:'Playfair Display',Georgia,serif;font-size:clamp(46px,5.8vw,82px);font-weight:400;font-style:italic;color:#F4EBD9;line-height:1.06;letter-spacing:-0.01em;margin:0 0 24px;">{{ section.settings.heading | default: "From Crop to Cup." }}</h1>
        
        <div style="display:flex;align-items:center;gap:16px;margin-bottom:20px;">
          <div style="height:1px;width:44px;background:#8B4513;flex-shrink:0;"></div>
          <span style="font-family:'Source Serif 4',Georgia,serif;font-size:11px;letter-spacing:0.22em;text-transform:uppercase;color:rgba(244,235,217,0.45);">Every Morning</span>
        </div>
        
        <p style="font-family:'Source Serif 4',Georgia,serif;font-size:14px;line-height:1.85;color:rgba(244,235,217,0.62);margin:0 0 36px;max-width:340px;">{{ section.settings.subheading | default: "Ethically sourced. Obsessively roasted. Delivered before sunrise." }}</p>
        
        <div style="display:flex;gap:14px;align-items:center;flex-wrap:wrap;padding-bottom:clamp(40px,6vw,100px);">
          <a href="/collections/all" style="background:#8B4513;color:#F4EBD9;text-decoration:none;padding:14px 34px;font-family:'Source Serif 4',Georgia,serif;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;transition:background 0.25s,color 0.25s;">Shop Blends →</a>
          <a href="/pages/our-story" style="color:rgba(244,235,217,0.62);text-decoration:none;font-family:'Source Serif 4',Georgia,serif;font-size:11px;letter-spacing:0.1em;border-bottom:1px solid rgba(244,235,217,0.25);padding-bottom:2px;transition:color 0.2s;">Our Story</a>
        </div>
      </div>
    </div>

    <div style="position:relative;overflow:hidden;">
      {%- if section.settings.image -%}
        <img src="{{ section.settings.image | image_url: width: 1600 }}" alt="GROUNDS coffee" loading="eager" style="width:100%;height:100%;object-fit:cover;object-position:center;display:block;">
      {%- endif -%}
      <div style="position:absolute;inset:0;background:linear-gradient(to right, rgba(44,24,16,0.4) 0%, transparent 35%);"></div>
      <div style="position:absolute;top:40px;right:40px;text-align:right;">
        <span style="font-family:'Source Serif 4',Georgia,serif;font-size:10px;letter-spacing:0.28em;text-transform:uppercase;color:rgba(244,235,217,0.55);">Specialty · Grade A</span>
      </div>
    </div>

  </div>

</section>

<style>
@media (max-width: 989px) {
  .grounds-hero-grid { grid-template-columns: 1fr !important; }
  .grounds-hero-grid > div:last-child { min-height: 52vh; }
  .grounds-hero-grid > div:first-child { padding: 48px 28px 52px !important; }
}
.grounds-hero a[href="/collections/all"]:hover { background: #6B3410 !important; }
.grounds-hero a[href="/pages/our-story"]:hover { color: #F4EBD9 !important; }
</style>

{% schema %}
{
  "name": "Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Coffee hero photograph"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From Crop to Cup."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Ethically sourced. Obsessively roasted. Delivered before sunrise."
    }
  ],
  "presets": [
    {
      "name": "Banner"
    }
  ]
}
{% endschema %}