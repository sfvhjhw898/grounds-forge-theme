{%- assign cv = product.selected_or_first_available_variant -%}

<div class="gp-wrap">

  <div class="gp-hero">
    {%- if product.featured_image -%}
      <img src="{{ product.featured_image | image_url: width: 1600 }}"
        alt="{{ product.featured_image.alt | escape }}"
        loading="eager" width="1600" height="900" class="gp-hero__img">
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'gp-hero__img' }}
    {%- endif -%}
    <div class="gp-hero__overlay">
      <p class="gp-hero__label">{{ product.type | default: 'Single Origin' }}</p>
      <h1 class="gp-hero__title">{{ product.title }}</h1>
    </div>
  </div>

  <div class="gp-body">

    <div class="gp-left">
      <div class="gp-origin-card">
        {%- if product.images.size > 1 -%}
          <img src="{{ product.images[1] | image_url: width: 600 }}"
            alt="{{ product.images[1].alt | escape }}"
            loading="lazy" class="gp-origin-img">
        {%- endif -%}
        <div class="gp-tags">
          {%- assign tags = product.tags -%}
          {%- for tag in tags limit: 4 -%}
            <span class="gp-tag">{{ tag }}</span>
          {%- endfor -%}
          {%- if product.tags.size == 0 -%}
            <span class="gp-tag">Specialty</span>
            <span class="gp-tag">Hand Roasted</span>
            <span class="gp-tag">Direct Trade</span>
          {%- endif -%}
        </div>
      </div>
    </div>

    <div class="gp-right">
      <p class="gp-vendor">{{ product.vendor | default: 'GROUNDS' }}</p>
      <div class="gp-desc">{{ product.description }}</div>

      <div class="gp-price-block">
        <span class="gp-price">{{ cv.price | money }}</span>
        {%- if cv.compare_at_price > cv.price -%}
          <span class="gp-was">Was {{ cv.compare_at_price | money }}</span>
        {%- endif -%}
      </div>

      {%- form 'product', product, id: 'gp-form' -%}
        {%- for option in product.options_with_values -%}
          <div class="gp-opt">
            <p class="gp-opt__label">{{ option.name }}</p>
            {%- if option.name == 'Grind' or option.name == 'Size' or option.name == 'Weight' -%}
              <div class="gp-radio-group">
                {%- for value in option.values -%}
                  <label class="gp-radio">
                    <input type="radio" name="option[{{ option.position }}]" value="{{ value }}"
                      {% if option.selected_value == value %}checked{% endif %}>
                    <span>{{ value }}</span>
                  </label>
                {%- endfor -%}
              </div>
            {%- else -%}
              <select name="option[{{ option.position }}]" class="gp-select">
                {%- for value in option.values -%}
                  <option value="{{ value }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
                {%- endfor -%}
              </select>
            {%- endif -%}
          </div>
        {%- endfor -%}
        <input type="hidden" name="id" value="{{ cv.id }}">
        <div class="gp-buy">
          <button type="submit" name="add" class="gp-btn">Order Now</button>
          <p class="gp-note">Roasted to order. Dispatched within 2 days.</p>
        </div>
      {%- endform -%}
    </div>

  </div>

</div>

<style>
.gp-wrap {
  background: #faf6ef;
  font-family: 'Georgia', serif;
}
.gp-hero {
  position: relative;
  height: 55vh;
  min-height: 380px;
  overflow: hidden;
}
.gp-hero__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 60%;
  display: block;
}
.gp-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(30,18,8,.75) 0%, transparent 60%);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 48px 60px;
}
.gp-hero__label {
  font-size: 11px;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: rgba(255,255,255,.7);
  margin: 0 0 10px;
}
.gp-hero__title {
  font-size: clamp(36px, 5vw, 64px);
  font-weight: 400;
  color: #fff;
  margin: 0;
  line-height: 1.1;
}
.gp-body {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 0;
  max-width: 1200px;
  margin: 0 auto;
  padding: 64px 60px;
  gap: 80px;
}
.gp-origin-card { }
.gp-origin-img {
  width: 100%;
  aspect-ratio: 4/5;
  object-fit: cover;
  display: block;
  margin-bottom: 20px;
}
.gp-tags { display: flex; flex-wrap: wrap; gap: 8px; }
.gp-tag {
  padding: 6px 14px;
  background: #e8dfd0;
  font-size: 11px;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: #5c3d1e;
}
.gp-vendor {
  font-size: 11px;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: #a07850;
  margin: 0 0 16px;
}
.gp-desc {
  font-size: 15px;
  line-height: 1.85;
  color: #3d2b1a;
  margin-bottom: 32px;
}
.gp-price-block { margin-bottom: 28px; }
.gp-price {
  font-size: 32px;
  color: #1e120a;
  display: block;
}
.gp-was { font-size: 14px; color: #a07850; text-decoration: line-through; }
.gp-opt { margin-bottom: 20px; }
.gp-opt__label {
  font-family: sans-serif;
  font-size: 10px;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: #a07850;
  margin: 0 0 12px;
}
.gp-radio-group { display: flex; gap: 8px; flex-wrap: wrap; }
.gp-radio input { display: none; }
.gp-radio span {
  display: block;
  padding: 9px 20px;
  border: 1px solid #c9b89a;
  font-size: 13px;
  font-family: sans-serif;
  color: #3d2b1a;
  cursor: pointer;
  transition: all .15s;
  background: transparent;
}
.gp-radio input:checked + span { background: #3d2b1a; color: #faf6ef; border-color: #3d2b1a; }
.gp-radio span:hover { border-color: #3d2b1a; }
.gp-select {
  width: 100%;
  padding: 12px 16px;
  border: 1px solid #c9b89a;
  background: #fff;
  font-size: 14px;
  font-family: sans-serif;
  color: #3d2b1a;
  appearance: none;
  cursor: pointer;
}
.gp-buy { }
.gp-btn {
  width: 100%;
  padding: 17px 24px;
  background: #3d2b1a;
  color: #faf6ef;
  border: none;
  font-size: 14px;
  letter-spacing: .1em;
  font-family: sans-serif;
  cursor: pointer;
  transition: background .2s;
  margin-bottom: 12px;
}
.gp-btn:hover { background: #5c3d1e; }
.gp-note {
  font-family: sans-serif;
  font-size: 12px;
  color: #a07850;
  text-align: center;
  margin: 0;
  font-style: italic;
}
@media (max-width: 768px) {
  .gp-body { grid-template-columns: 1fr; gap: 40px; padding: 40px 24px; }
  .gp-hero__overlay { padding: 32px 24px; }
  .gp-origin-img { aspect-ratio: 16/9; }
}
</style>

{% schema %}
{
  "name": "GROUNDS Product",
  "tag": "section",
  "class": "forge-product-grounds"
}
{% endschema %}
