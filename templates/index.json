        "cell_3_stat_label": "Average Altitude",
        "cell_3_body": "Higher altitude means slower ripening, more complexity, and better flavour.",
        "cell_4_heading": "Roasted to Order",
        "cell_4_body": "We roast fresh when you order. Never sitting in a warehouse. Always at peak flavour.",
        "cell_5_heading": "Subscription",
